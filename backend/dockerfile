FROM python:3.9-slim

WORKDIR /app

# Copy and install dependencies
COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

# Copy the backend code
COPY neuralprot_backend.py .
COPY neuralprot_inference.py .

# If you have go_dict.json locally, copy it too (optional)
# COPY go_dict.json .

# Environment variable for the model repository (set this in Space settings too)
ENV HF_REPO_ID=cod3astro/neuralprot_beta

# Expose the port
EXPOSE 7860

# Start the server
CMD ["uvicorn", "neuralprot_backend:app", "--host", "0.0.0.0", "--port", "7860"]